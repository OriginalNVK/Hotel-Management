// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RoomType {
  type                    String   @id @db.Char(1)
  price                   Int
  maxOccupancy            Int
  surchargeRate           Float
  minCustomerForSurcharge Int
  rooms                   Room[]

  @@map("roomtype")
}

model Room {
  roomId      Int                @id
  type        String             @db.Char(1)
  isAvailable Boolean            @default(true)
  description String?
  imgUrl      String?
  roomType    RoomType           @relation(fields: [type], references: [type])
  bookings    Booking[]
  occupancy   OccupancyHasRoom[]

  @@map("room")
}

model CustomerType {
  type         Int        @id @default(autoincrement())
  name         String     @db.VarChar(10)
  coefficient  Float
  customers    Customer[]

  @@map("customertype")
}

model Customer {
  customerId      Int                @id @default(autoincrement())
  name            String             @db.VarChar(40)
  address         String?            @db.VarChar(100)
  identityCard    String             @db.VarChar(12)
  type            Int
  customerType    CustomerType       @relation(fields: [type], references: [type])
  invoices        Invoice[]
  bookingCustomers BookingCustomer[]

  @@map("customer")
}

model Invoice {
  invoiceId       Int        @id @default(autoincrement())
  representativeId Int
  invoiceDate     DateTime   @db.Date
  amount          Float
  representative  Customer   @relation(fields: [representativeId], references: [customerId])
  bookings        Booking[]

  @@map("invoice")
}

model Booking {
  bookingId       Int              @id @default(autoincrement())
  roomId          Int
  bookingDate     DateTime         @db.Date
  cost            Float?
  invoiceId       Int?
  room            Room             @relation(fields: [roomId], references: [roomId])
  invoice         Invoice?         @relation(fields: [invoiceId], references: [invoiceId])
  bookingCustomers BookingCustomer[]

  @@map("booking")
}

model BookingCustomer {
  bookingId  Int
  customerId Int
  booking    Booking  @relation(fields: [bookingId], references: [bookingId])
  customer   Customer @relation(fields: [customerId], references: [customerId])

  @@id([bookingId, customerId])
  @@map("bookingcustomers")
}

model RevenueReport {
  month                  Int
  year                   Int
  totalRevenue           Float
  revenueReportHasRoomTypes RevenueReportHasRoomType[]

  @@id([month, year])
  @@map("revenuereport")
}

model RevenueReportHasRoomType {
  month         Int
  year          Int
  type          String
  revenue       Float
  revenueReport RevenueReport @relation(fields: [month, year], references: [month, year])

  @@id([month, year, type])
  @@map("revenuereport_has_roomtype")
}

model Occupancy {
  month             Int
  year              Int
  totalRentalDay    Float
  occupancyHasRooms OccupancyHasRoom[]

  @@id([month, year])
  @@map("occupancy")
}

model OccupancyHasRoom {
  month     Int
  year      Int
  roomId    Int
  rentalDays Float
  occupancy Occupancy @relation(fields: [month, year], references: [month, year])
  room      Room      @relation(fields: [roomId], references: [roomId])

  @@id([month, year, roomId])
  @@map("occupancy_has_room")
}
